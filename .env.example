# Copy to .env.local (gitignored) for local dev, and set the same in Vercel.
# Until BOTH are set, the app runs un-gated (no sign-in required).
# Get these from Supabase → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# NOTE: never put the Supabase service-role key in any VITE_ var — it's client-exposed.
